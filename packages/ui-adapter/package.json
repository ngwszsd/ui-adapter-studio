  "files": [
    "dist"
  ],
  "typesVersions": {
    "*": {
      "Editor": [
        "dist/Editor.d.ts"
      ],
      "Canvas": [
        "dist/Canvas.d.ts"
      ],
      "Toolbox": [
        "dist/Toolbox.d.ts"
      ],
      "PropertyPanel": [
        "dist/PropertyPanel.d.ts"
      ],
      "PageItem": [
        "dist/PageItem.d.ts"
      ],
      "components/Viewport": [
        "dist/components/Viewport.d.ts"
      ],
      "components/container": [
        "dist/components/container/index.d.ts"
      ],
      "components/display": [
        "dist/components/display/index.d.ts"
      ],
      "components/input": [
        "dist/components/input/index.d.ts"
      ],
      "components/shared": [
        "dist/components/shared/index.d.ts"
      ],
      "store/useDesignerStore": [
        "dist/store/useDesignerStore.d.ts"
      ],
      "types": [
        "dist/types/index.d.ts"
      ],
      "persistence": [
        "dist/persistence/index.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "sideEffects": false
}
