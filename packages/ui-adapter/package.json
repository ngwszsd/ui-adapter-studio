{
  "name": "@teamhelper/ui-adapter",
  "version": "0.0.1",
  "description": "UI Adapter for drag and drop orchestration",
  "author": "garvin",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@craftjs/core": "^0.2.12",
    "@craftjs/layers": "^0.2.7",
    "@craftjs/utils": "^0.2.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.19",
    "@teamhelper/ui": "^1.0.24",
    "@uiw/react-codemirror": "^4.25.8",
    "@uiw/react-color-sketch": "^2.9.5",
    "clsx": "^2.1.1",
    "immer": "^10.2.0",
    "ky": "^1.14.3",
    "lucide-react": "^0.554.0",
    "nanoid": "^5.1.6",
    "re-resizable": "^6.10.3",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./Editor": {
      "types": "./dist/Editor.d.ts",
      "import": "./dist/Editor.js",
      "require": "./dist/Editor.cjs"
    },
    "./Canvas": {
      "types": "./dist/Canvas.d.ts",
      "import": "./dist/Canvas.js",
      "require": "./dist/Canvas.cjs"
    },
    "./Toolbox": {
      "types": "./dist/Toolbox.d.ts",
      "import": "./dist/Toolbox.js",
      "require": "./dist/Toolbox.cjs"
    },
    "./PropertyPanel": {
      "types": "./dist/PropertyPanel.d.ts",
      "import": "./dist/PropertyPanel.js",
      "require": "./dist/PropertyPanel.cjs"
    },
    "./PageItem": {
      "types": "./dist/PageItem.d.ts",
      "import": "./dist/PageItem.js",
      "require": "./dist/PageItem.cjs"
    },
    "./components/Viewport": {
      "types": "./dist/components/Viewport.d.ts",
      "import": "./dist/components/Viewport.js",
      "require": "./dist/components/Viewport.cjs"
    },
    "./components/container": {
      "types": "./dist/components/container/index.d.ts",
      "import": "./dist/components/container/index.js",
      "require": "./dist/components/container/index.cjs"
    },
    "./components/display": {
      "types": "./dist/components/display/index.d.ts",
      "import": "./dist/components/display/index.js",
      "require": "./dist/components/display/index.cjs"
    },
    "./components/input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js",
      "require": "./dist/components/input/index.cjs"
    },
    "./components/shared": {
      "types": "./dist/components/shared/index.d.ts",
      "import": "./dist/components/shared/index.js",
      "require": "./dist/components/shared/index.cjs"
    },
    "./store/useDesignerStore": {
      "types": "./dist/store/useDesignerStore.d.ts",
      "import": "./dist/store/useDesignerStore.js",
      "require": "./dist/store/useDesignerStore.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js",
      "require": "./dist/persistence/index.cjs"
    },
    "./package.json": "./package.json"
